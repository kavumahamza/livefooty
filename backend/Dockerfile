FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]

# Default: run the web process (gunicorn).
# The poller service overrides this CMD with: python manage.py run_poller
CMD ["gunicorn", "footy.wsgi:application", "--bind", "0.0.0.0:8000", "--workers", "3"]
