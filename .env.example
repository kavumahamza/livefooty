# -----------------------------------------------------------------------
# Football Live — environment configuration
# Copy to .env and edit before running: cp .env.example .env
# -----------------------------------------------------------------------

# Data provider: "mock" for local demo, "api_football" for live data
PROVIDER=mock

# API-Football key (only needed when PROVIDER=api_football)
API_FOOTBALL_KEY=

# Redis connection (matches the compose service name)
REDIS_URL=redis://redis:6379/0

# How often the poller fetches fresh data, in seconds
POLL_INTERVAL=20

# Django security — CHANGE before any public deployment
DJANGO_SECRET_KEY=change-me

# Set to 0 in production; 1 enables the debug toolbar / verbose errors
DJANGO_DEBUG=0

# Comma-separated list of hosts Django will serve
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
